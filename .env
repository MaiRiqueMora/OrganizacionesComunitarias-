# Sistema Municipal - Variables de Entorno (Desarrollo)
# No versionar este archivo en producción

# ── Base de Datos ────────────────────────────────────────
DB_HOST=localhost
DB_NAME=munidb_v2
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# ── SMTP (Correo) ────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tucorreo@gmail.com
SMTP_PASS=xxxx xxxx xxxx xxxx
SMTP_FROM=tucorreo@gmail.com
SMTP_FROM_NAME="Municipalidad — Sistema de Organizaciones"

# ── Aplicación ───────────────────────────────────────────
APP_NAME="Sistema de Organizaciones"
APP_URL=http://localhost/sistema-municipal
TOKEN_EXPIRY=3600

# ── Subida de Archivos ───────────────────────────────────
UPLOAD_DIR=uploads/
UPLOAD_MAX_MB=10

# ── Configuración del Sistema ───────────────────────────────
ALERTA_DIAS_ANTES=30
TIMEZONE=America/Santiago

# ── Seguridad ─────────────────────────────────────────────
APP_ENV=development

# ── Debug (solo para desarrollo) ───────────────────────────
DEBUG=true
LOG_ERRORS=true
